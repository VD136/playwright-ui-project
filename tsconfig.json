{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020","DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
     "resolveJsonModule": true
  },
  "include": [
    "tests/**/*",
    "pages/**/*",
    "fixtures/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
